          <material>
            <ambient>0.65 0.65 0.65 1</ambient>
            <diffuse>0.80 0.80 0.80 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <model name='overhead_camera_model'>
      <static>1</static>
      <link name='overhead_camera_link'>
        <pose>0.619308 0.874419 1.18362 0.027906 0.947704 -3.09384</pose>
        <visual name='visual'>
          <geometry>
            <box>
              <size>0.08 0.08 0.04</size>
            </box>
          </geometry>
          <material>
            <ambient>0.1 0.1 0.1 1</ambient>
            <diffuse>0.1 0.1 0.1 1</diffuse>
          </material>
        </visual>
        <sensor name='overhead_camera' type='camera'>
          <update_rate>30</update_rate>
          <pose>0 0 0 0 0 0</pose>
          <camera>
            <horizontal_fov>1.6</horizontal_fov>
            <image>
              <width>800</width>
              <height>600</height>
              <format>R8G8B8</format>
            </image>
            <clip>
              <near>0.2</near>
              <far>10</far>
            </clip>
          </camera>
          <plugin name='camera_controller' filename='libgazebo_ros_camera.so'>
            <alwaysOn>1</alwaysOn>
            <updateRate>30.0</updateRate>
            <cameraName>overhead_camera</cameraName>
            <imageTopicName>image_raw</imageTopicName>
            <frameName>overhead_camera_link</frameName>
          </plugin>
        </sensor>
      </link>
    </model>

